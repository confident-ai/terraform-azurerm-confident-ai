# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain secrets
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Transient lock info created during apply
.terraform.tfstate.lock.info

# Plan output files
*tfplan*

# CLI configuration files
.terraformrc
terraform.rc

# macOS
.DS_Store

# Misc
DEPLOY.md

# Terraform state backend config (kept out of the published module)
backend.tf

# Helm values
values.yaml
values.*.yaml
